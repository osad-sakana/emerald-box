---
interface Props {
  title?: string
}
const { title = 'Emerald Box — AI Web Sandbox' } = Astro.props
---

<!doctype html>
<html lang="ja" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ブラウザ内で完結するHTML/CSS/JSプレビューツール" />
    <title>{title}</title>
  </head>
  <body class="h-full overflow-hidden bg-slate-950 font-sans text-slate-100 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    height: 100%;
  }
</style>
