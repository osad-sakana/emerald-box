---
import { SNIPPETS } from '../lib/snippets'

const targetLabel: Record<string, string> = {
  html: 'HTML',
  css: 'CSS',
  javascript: 'JS',
}
---

<aside class="flex w-64 shrink-0 flex-col border-r border-slate-800 bg-slate-900">
  <h2
    class="border-b border-slate-800 px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-400"
  >
    スニペット
  </h2>
  <nav class="flex-1 overflow-y-auto p-2">
    <ul class="space-y-1">
      {
        SNIPPETS.map((snippet) => (
          <li>
            <button
              type="button"
              class="snippet-item group flex w-full flex-col items-start rounded-md px-3 py-2 text-left transition hover:bg-slate-800"
              data-snippet-id={snippet.id}
            >
              <span class="flex w-full items-center justify-between">
                <span class="text-sm font-medium text-slate-200 group-hover:text-emerald-400">
                  {snippet.label}
                </span>
                <span class="rounded bg-slate-800 px-1.5 py-0.5 font-mono text-[10px] text-emerald-400 group-hover:bg-slate-700">
                  {targetLabel[snippet.target]}
                </span>
              </span>
              <span class="mt-0.5 text-xs text-slate-500">
                {snippet.description}
              </span>
            </button>
          </li>
        ))
      }
    </ul>
  </nav>
  <p class="border-t border-slate-800 px-4 py-3 text-[11px] leading-relaxed text-slate-500">
    クリックで対象タブの末尾にコードを挿入します。
  </p>
</aside>
