---
import { LICENSES, MIT_LICENSE_TEXT, OFL_NOTICE_TEXT } from '../lib/licenses'

const mitEntries = LICENSES.filter((l) => l.license.startsWith('MIT'))
const oflEntries = LICENSES.filter((l) => l.license.startsWith('SIL'))
---

<!-- ライセンス表示モーダル。初期状態は非表示。 -->
<div
  id="credits-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="credits-title"
>
  <!-- 背景オーバーレイ -->
  <div id="credits-backdrop" class="absolute inset-0 bg-black/60"></div>

  <!-- モーダル本体 -->
  <div
    class="relative flex max-h-[80vh] w-full max-w-2xl flex-col overflow-hidden rounded-xl border border-emerald-800 bg-slate-900 shadow-2xl"
  >
    <header
      class="flex items-center justify-between border-b border-slate-800 px-5 py-3"
    >
      <h2 id="credits-title" class="text-base font-bold text-slate-100">
        ライセンス・クレジット
      </h2>
      <button
        id="credits-close"
        type="button"
        class="rounded-md px-2 py-1 text-slate-400 transition hover:bg-slate-800 hover:text-emerald-400"
        aria-label="閉じる"
      >
        ✕
      </button>
    </header>

    <div class="overflow-y-auto px-5 py-4 text-sm leading-relaxed text-slate-300">
      <p class="mb-4 text-slate-400">
        Emerald Box は以下のオープンソースソフトウェアおよびフォントを利用しています。
      </p>

      <ul class="mb-6 space-y-2">
        {
          LICENSES.map((entry) => (
            <li class="rounded-md border border-slate-800 bg-slate-950/50 px-3 py-2">
              <div class="flex items-center justify-between gap-2">
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-emerald-400 hover:underline"
                >
                  {entry.name}
                  {entry.version && (
                    <span class="ml-1 text-xs text-slate-500">v{entry.version}</span>
                  )}
                </a>
                <span class="shrink-0 rounded bg-slate-800 px-2 py-0.5 text-[11px] text-slate-300">
                  {entry.license}
                </span>
              </div>
              <p class="mt-1 text-xs text-slate-500">{entry.copyright}</p>
            </li>
          ))
        }
      </ul>

      <section class="mb-5">
        <h3 class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-400">
          MIT License
        </h3>
        <p class="mb-2 text-xs text-slate-500">
          適用: {mitEntries.map((e) => e.name).join('、')}
        </p>
        <pre
          class="whitespace-pre-wrap rounded-md bg-slate-950 p-3 text-[11px] leading-relaxed text-slate-400">{MIT_LICENSE_TEXT}</pre>
      </section>

      <section>
        <h3 class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-400">
          SIL Open Font License 1.1
        </h3>
        <p class="mb-2 text-xs text-slate-500">
          適用: {oflEntries.map((e) => e.name).join('、')}
        </p>
        <pre
          class="whitespace-pre-wrap rounded-md bg-slate-950 p-3 text-[11px] leading-relaxed text-slate-400">{OFL_NOTICE_TEXT}</pre>
      </section>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('credits-modal')
  const openBtn = document.getElementById('btn-credits')
  const closeBtn = document.getElementById('credits-close')
  const backdrop = document.getElementById('credits-backdrop')

  const open = () => {
    modal?.classList.remove('hidden')
    modal?.classList.add('flex')
  }
  const close = () => {
    modal?.classList.add('hidden')
    modal?.classList.remove('flex')
  }

  openBtn?.addEventListener('click', open)
  closeBtn?.addEventListener('click', close)
  backdrop?.addEventListener('click', close)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) close()
  })
</script>
