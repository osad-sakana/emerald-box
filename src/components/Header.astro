---
// アプリ最上部のヘッダー。左にアプリ名、右に操作ボタン群。
// base 付き環境でも壊れないようアイコンのパスを正規化する。
const iconUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`
---

<header
  class="flex items-center justify-between border-b border-emerald-800 bg-slate-900 px-4 py-2.5"
>
  <div class="flex items-center gap-2">
    <img
      src={iconUrl}
      alt="Emerald Box"
      width="28"
      height="28"
      class="h-7 w-7 drop-shadow-[0_0_6px_rgba(16,185,129,0.45)]"
    />
    <h1 class="flex items-baseline gap-2">
      <span
        class="bg-gradient-to-r from-emerald-300 via-emerald-400 to-emerald-600 bg-clip-text text-lg font-extrabold tracking-tight text-transparent"
      >
        Emerald Box
      </span>
      <span
        class="rounded-full border border-emerald-700/60 bg-emerald-500/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300"
      >
        Web Sandbox
      </span>
    </h1>
  </div>

  <div class="flex items-center gap-2">
    <span
      id="save-status"
      class="mr-1 hidden text-xs text-emerald-400 sm:inline"
      aria-live="polite"></span>

    <button
      id="btn-run"
      type="button"
      class="rounded-md bg-emerald-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-emerald-500 active:scale-95"
    >
      ▶ JS実行
    </button>

    <button
      id="btn-stop"
      type="button"
      class="rounded-md bg-slate-700 px-3 py-1.5 text-sm font-semibold text-slate-100 transition hover:bg-red-600 active:scale-95"
    >
      ■ 強制終了
    </button>

    <button
      id="btn-reset"
      type="button"
      class="rounded-md bg-slate-700 px-3 py-1.5 text-sm font-semibold text-slate-100 transition hover:bg-amber-600 active:scale-95"
    >
      環境初期化
    </button>

    <button
      id="btn-credits"
      type="button"
      class="rounded-md border border-slate-700 px-2.5 py-1.5 text-sm font-medium text-slate-400 transition hover:border-emerald-700 hover:text-emerald-400"
      aria-label="ライセンス表示"
    >
      ⓘ ライセンス
    </button>
  </div>
</header>
