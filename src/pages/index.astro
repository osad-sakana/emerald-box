---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Credits from '../components/Credits.astro'
---

<Layout>
  <div class="flex h-full flex-col">
    <Header />

    <main class="flex min-h-0 flex-1">
      <!-- 左: エディタエリア -->
      <section class="flex min-w-0 flex-1 flex-col bg-slate-950">
        <!-- タブ -->
        <div class="flex items-center gap-1 border-b border-slate-800 bg-slate-900 px-2 py-1.5">
          <button
            type="button"
            class="editor-tab rounded-md px-3 py-1 text-sm font-medium transition"
            data-lang="html"
          >
            HTML
          </button>
          <button
            type="button"
            class="editor-tab rounded-md px-3 py-1 text-sm font-medium transition"
            data-lang="css"
          >
            CSS
          </button>
          <button
            type="button"
            class="editor-tab rounded-md px-3 py-1 text-sm font-medium transition"
            data-lang="javascript"
          >
            JS
          </button>
        </div>
        <!-- Monaco コンテナ -->
        <div id="editor" class="min-h-0 flex-1"></div>
      </section>

      <!-- 右: ライブプレビュー -->
      <section class="flex min-w-0 flex-1 flex-col border-l border-slate-800">
        <div
          class="flex items-center justify-between border-b border-slate-800 bg-slate-900 px-3 py-1.5"
        >
          <span class="text-xs font-bold uppercase tracking-wider text-slate-400"
            >プレビュー</span
          >
          <span class="font-mono text-[10px] text-slate-500">HTML/CSS は自動反映・JS は手動実行</span>
        </div>
        <div id="preview-host" class="min-h-0 flex-1 bg-white"></div>
      </section>
    </main>
  </div>

  <Credits />
</Layout>

<script>
  import loader from '@monaco-editor/loader'
  import {
    loadCode,
    saveCode,
    clearCode,
    debounce,
    type CodeState,
    type EditorLang,
  } from '../lib/storage'
  import { PreviewController } from '../lib/preview'

  // Monaco を CDN から読み込む。
  loader.config({
    paths: {
      vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs',
    },
  })

  const ACTIVE_TAB = ['bg-slate-950', 'text-emerald-400']
  const INACTIVE_TAB = ['text-slate-400', 'hover:text-slate-200']

  async function init() {
    const monaco = await loader.init()

    const initial = loadCode()

    // HTML/CSS/JS それぞれに独立したモデルを用意する。
    const models: Record<EditorLang, ReturnType<typeof monaco.editor.createModel>> =
      {
        html: monaco.editor.createModel(initial.html, 'html'),
        css: monaco.editor.createModel(initial.css, 'css'),
        javascript: monaco.editor.createModel(initial.javascript, 'javascript'),
      }

    const container = document.getElementById('editor')!
    const editor = monaco.editor.create(container, {
      model: models.html,
      theme: 'vs-dark',
      automaticLayout: true,
      fontSize: 14,
      fontFamily: '"0xProto", ui-monospace, monospace',
      minimap: { enabled: false },
      scrollBeyondLastLine: false,
      tabSize: 2,
      padding: { top: 12 },
    })

    const host = document.getElementById('preview-host')!
    const preview = new PreviewController(host)

    const getState = (): CodeState => ({
      html: models.html.getValue(),
      css: models.css.getValue(),
      javascript: models.javascript.getValue(),
    })

    // 保存ステータス表示。
    const statusEl = document.getElementById('save-status')!
    let statusTimer: ReturnType<typeof setTimeout> | undefined
    const flashSaved = () => {
      statusEl.textContent = '✓ 自動保存しました'
      statusEl.classList.remove('hidden')
      if (statusTimer) clearTimeout(statusTimer)
      statusTimer = setTimeout(() => statusEl.classList.add('hidden'), 1500)
    }

    // 500ms デバウンスで自動保存。
    const persist = debounce(() => {
      saveCode(getState())
      flashSaved()
    }, 500)

    // 初回プレビュー（HTML/CSS のみ）。
    preview.renderMarkup(getState())

    // タブ切り替え。
    let activeLang: EditorLang = 'html'
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.editor-tab')
    )
    const syncTabs = () => {
      for (const tab of tabs) {
        const isActive = tab.dataset.lang === activeLang
        tab.classList.toggle('bg-slate-950', isActive)
        tab.classList.toggle('text-emerald-400', isActive)
        tab.classList.toggle('text-slate-400', !isActive)
        tab.classList.toggle('hover:text-slate-200', !isActive)
      }
    }
    const switchLang = (lang: EditorLang) => {
      activeLang = lang
      editor.setModel(models[lang])
      syncTabs()
      editor.focus()
    }
    for (const tab of tabs) {
      tab.addEventListener('click', () =>
        switchLang(tab.dataset.lang as EditorLang)
      )
    }
    syncTabs()

    // 各モデルの変更を監視。HTML/CSS は即時にプレビュー反映、JS は保存のみ。
    models.html.onDidChangeContent(() => {
      preview.renderMarkup(getState())
      persist()
    })
    models.css.onDidChangeContent(() => {
      preview.renderMarkup(getState())
      persist()
    })
    models.javascript.onDidChangeContent(() => {
      persist()
    })

    // ▶ JS実行
    document.getElementById('btn-run')!.addEventListener('click', () => {
      preview.runWithJs(getState())
    })

    // ■ 強制終了: iframe を破棄・再生成して HTML/CSS のみ再描画。
    document.getElementById('btn-stop')!.addEventListener('click', () => {
      preview.forceStop(getState())
    })

    // 環境初期化: localStorage をクリアしてリロード。
    document.getElementById('btn-reset')!.addEventListener('click', () => {
      const ok = confirm(
        '保存されたコードをすべて削除して初期状態に戻します。よろしいですか？'
      )
      if (!ok) return
      clearCode()
      location.reload()
    })
  }

  init().catch((error) => {
    console.error('エディタの初期化に失敗しました:', error)
  })
</script>
