---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Credits from '../components/Credits.astro'
---

<Layout>
  <div class="flex h-full flex-col">
    <Header />

    <main class="flex min-h-0 flex-1 flex-col bg-slate-950">
      <!-- 各ペインの表示トグル -->
      <div class="flex items-center gap-1 border-b border-slate-800 bg-slate-900 px-2 py-1.5">
        <span class="mr-1 text-[11px] font-medium text-slate-500">表示:</span>
        <button
          type="button"
          class="panel-toggle rounded-md px-3 py-1 text-sm font-medium transition"
          data-pane="html"
          aria-pressed="true"
        >
          HTML
        </button>
        <button
          type="button"
          class="panel-toggle rounded-md px-3 py-1 text-sm font-medium transition"
          data-pane="css"
          aria-pressed="true"
        >
          CSS
        </button>
        <button
          type="button"
          class="panel-toggle rounded-md px-3 py-1 text-sm font-medium transition"
          data-pane="javascript"
          aria-pressed="true"
        >
          JS
        </button>
        <button
          type="button"
          class="panel-toggle rounded-md px-3 py-1 text-sm font-medium transition"
          data-pane="preview"
          aria-pressed="true"
        >
          プレビュー
        </button>
      </div>

      <!-- 4ペイン本体（HTML/CSS/JS/プレビュー）。ガターをドラッグして幅を変更できる。 -->
      <div id="panes" class="flex min-h-0 flex-1">
        <div id="pane-html" class="editor-pane flex min-w-0 flex-col" data-pane="html">
          <div class="border-b border-slate-800 bg-slate-900 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-400">
            HTML
          </div>
          <div id="editor-html" class="min-h-0 flex-1"></div>
        </div>

        <div
          id="gutter-css"
          class="pane-gutter w-1.5 shrink-0 cursor-col-resize bg-slate-800 transition hover:bg-emerald-600"
          data-pane="css"
          role="separator"
          aria-orientation="vertical"
          title="ドラッグして幅を変更"
        >
        </div>

        <div id="pane-css" class="editor-pane flex min-w-0 flex-col" data-pane="css">
          <div class="border-b border-slate-800 bg-slate-900 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-400">
            CSS
          </div>
          <div id="editor-css" class="min-h-0 flex-1"></div>
        </div>

        <div
          id="gutter-javascript"
          class="pane-gutter w-1.5 shrink-0 cursor-col-resize bg-slate-800 transition hover:bg-emerald-600"
          data-pane="javascript"
          role="separator"
          aria-orientation="vertical"
          title="ドラッグして幅を変更"
        >
        </div>

        <div
          id="pane-javascript"
          class="editor-pane flex min-w-0 flex-col"
          data-pane="javascript"
        >
          <div class="border-b border-slate-800 bg-slate-900 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-400">
            JavaScript
          </div>
          <div id="editor-javascript" class="min-h-0 flex-1"></div>
        </div>

        <div
          id="gutter-preview"
          class="pane-gutter w-1.5 shrink-0 cursor-col-resize bg-slate-800 transition hover:bg-emerald-600"
          data-pane="preview"
          role="separator"
          aria-orientation="vertical"
          title="ドラッグして幅を変更"
        >
        </div>

        <div
          id="pane-preview"
          class="editor-pane flex min-w-0 flex-col border-l border-slate-800"
          data-pane="preview"
        >
          <div
            class="flex items-center justify-between border-b border-slate-800 bg-slate-900 px-3 py-1"
          >
            <span class="text-[11px] font-bold uppercase tracking-wider text-emerald-400"
              >プレビュー</span
            >
            <span class="text-[10px] text-slate-500">HTML/CSS は自動反映・JS は手動実行</span>
          </div>
          <div id="preview-host" class="min-h-0 flex-1 bg-white"></div>
        </div>

        <!-- 全ペイン非表示時の案内 -->
        <div
          id="panes-empty"
          class="hidden flex-1 items-center justify-center p-6 text-center text-sm text-slate-600"
        >
          上の「表示」からペインを開いてください。
        </div>
      </div>
    </main>
  </div>

  <Credits />
</Layout>

<script>
  import loader from '@monaco-editor/loader'
  import {
    loadCode,
    saveCode,
    clearCode,
    loadPanels,
    savePanels,
    loadSizes,
    saveSizes,
    debounce,
    PANE_KEYS,
    type CodeState,
    type PanelState,
    type PanelSizes,
    type EditorLang,
    type PaneKey,
  } from '../lib/storage'
  import { PreviewController } from '../lib/preview'

  // Monaco を CDN から読み込む。
  loader.config({
    paths: {
      vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs',
    },
  })

  const LANGS: EditorLang[] = ['html', 'css', 'javascript']
  const isEditorLang = (k: PaneKey): k is EditorLang => k !== 'preview'

  async function init() {
    const monaco = await loader.init()

    const initial = loadCode()

    // HTML/CSS/JS それぞれに独立したモデルを用意する。
    const models: Record<EditorLang, ReturnType<typeof monaco.editor.createModel>> =
      {
        html: monaco.editor.createModel(initial.html, 'html'),
        css: monaco.editor.createModel(initial.css, 'css'),
        javascript: monaco.editor.createModel(initial.javascript, 'javascript'),
      }

    // 各ペインに独立した Monaco エディタを生成する。
    const makeEditor = (lang: EditorLang) =>
      monaco.editor.create(document.getElementById(`editor-${lang}`)!, {
        model: models[lang],
        theme: 'vs-dark',
        automaticLayout: true,
        fontSize: 14,
        fontFamily: '"0xProto", ui-monospace, monospace',
        minimap: { enabled: false },
        scrollBeyondLastLine: false,
        tabSize: 2,
        padding: { top: 12 },
      })
    const editors: Record<EditorLang, ReturnType<typeof makeEditor>> = {
      html: makeEditor('html'),
      css: makeEditor('css'),
      javascript: makeEditor('javascript'),
    }

    const host = document.getElementById('preview-host')!
    const preview = new PreviewController(host)

    const getState = (): CodeState => ({
      html: models.html.getValue(),
      css: models.css.getValue(),
      javascript: models.javascript.getValue(),
    })

    // 保存ステータス表示。
    const statusEl = document.getElementById('save-status')!
    let statusTimer: ReturnType<typeof setTimeout> | undefined
    const flashSaved = () => {
      statusEl.textContent = '✓ 自動保存しました'
      statusEl.classList.remove('hidden')
      if (statusTimer) clearTimeout(statusTimer)
      statusTimer = setTimeout(() => statusEl.classList.add('hidden'), 1500)
    }

    // 500ms デバウンスで自動保存。
    const persist = debounce(() => {
      saveCode(getState())
      flashSaved()
    }, 500)

    // 初回プレビュー（HTML/CSS のみ）。
    preview.renderMarkup(getState())

    // ペインの表示/非表示と相対サイズ。いずれも localStorage に永続化する。
    let panels: PanelState = loadPanels()
    let sizes: PanelSizes = loadSizes()
    const emptyEl = document.getElementById('panes-empty')!
    const toggleBtns = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.panel-toggle')
    )
    const MIN_PANE_PX = 120

    // 該当ペインがエディタなら Monaco のレイアウトを再計算する。
    const relayout = (key: PaneKey) => {
      if (isEditorLang(key)) editors[key].layout()
    }

    // 相対サイズ（flex-grow）を各ペインへ反映する。
    const applySizes = () => {
      for (const key of PANE_KEYS) {
        const pane = document.getElementById(`pane-${key}`)!
        pane.style.flex = `${sizes[key]} 1 0%`
      }
    }

    // ガター X の左側にある「直近の表示ペイン」を返す。
    const nearestLeftVisible = (key: PaneKey): PaneKey | null => {
      const idx = PANE_KEYS.indexOf(key)
      for (let i = idx - 1; i >= 0; i--) {
        if (panels[PANE_KEYS[i]]) return PANE_KEYS[i]
      }
      return null
    }

    const syncPanels = () => {
      for (const key of PANE_KEYS) {
        const visible = panels[key]
        const pane = document.getElementById(`pane-${key}`)!
        pane.classList.toggle('hidden', !visible)
        if (visible) relayout(key)
      }
      // ガターは「自分が表示」かつ「左に表示ペインがある」ときだけ出す。
      for (const key of PANE_KEYS) {
        const gutter = document.getElementById(`gutter-${key}`)
        if (!gutter) continue
        const show = panels[key] && nearestLeftVisible(key) !== null
        gutter.classList.toggle('hidden', !show)
      }
      for (const btn of toggleBtns) {
        const visible = panels[btn.dataset.pane as PaneKey]
        btn.setAttribute('aria-pressed', String(visible))
        btn.classList.toggle('bg-emerald-600', visible)
        btn.classList.toggle('text-white', visible)
        btn.classList.toggle('text-slate-400', !visible)
        btn.classList.toggle('hover:text-slate-200', !visible)
      }
      // すべて非表示なら案内を出す。
      const anyVisible = PANE_KEYS.some((key) => panels[key])
      emptyEl.classList.toggle('hidden', anyVisible)
      emptyEl.classList.toggle('flex', !anyVisible)
    }

    for (const btn of toggleBtns) {
      btn.addEventListener('click', () => {
        const key = btn.dataset.pane as PaneKey
        panels = { ...panels, [key]: !panels[key] }
        savePanels(panels)
        syncPanels()
      })
    }

    applySizes()
    syncPanels()

    // ガターのドラッグで隣接2ペインの相対サイズを変更する。
    for (const gutter of document.querySelectorAll<HTMLElement>('.pane-gutter')) {
      gutter.addEventListener('pointerdown', (e: PointerEvent) => {
        const rightKey = gutter.dataset.pane as PaneKey
        const leftKey = nearestLeftVisible(rightKey)
        if (!leftKey) return

        const leftEl = document.getElementById(`pane-${leftKey}`)!
        const rightEl = document.getElementById(`pane-${rightKey}`)!
        const leftW = leftEl.getBoundingClientRect().width
        const rightW = rightEl.getBoundingClientRect().width
        const totalPx = leftW + rightW
        const totalGrow = sizes[leftKey] + sizes[rightKey]
        const startX = e.clientX

        gutter.setPointerCapture(e.pointerId)
        document.body.style.cursor = 'col-resize'
        document.body.style.userSelect = 'none'

        const onMove = (ev: PointerEvent) => {
          const delta = ev.clientX - startX
          const newLeftPx = Math.min(
            Math.max(leftW + delta, MIN_PANE_PX),
            totalPx - MIN_PANE_PX
          )
          const ratio = newLeftPx / totalPx
          sizes = {
            ...sizes,
            [leftKey]: totalGrow * ratio,
            [rightKey]: totalGrow * (1 - ratio),
          }
          applySizes()
          relayout(leftKey)
          relayout(rightKey)
        }

        const onUp = () => {
          gutter.releasePointerCapture(e.pointerId)
          document.body.style.cursor = ''
          document.body.style.userSelect = ''
          gutter.removeEventListener('pointermove', onMove)
          gutter.removeEventListener('pointerup', onUp)
          saveSizes(sizes)
        }

        gutter.addEventListener('pointermove', onMove)
        gutter.addEventListener('pointerup', onUp)
      })
    }

    // 各モデルの変更を監視。HTML/CSS は即時にプレビュー反映、JS は保存のみ。
    models.html.onDidChangeContent(() => {
      preview.renderMarkup(getState())
      persist()
    })
    models.css.onDidChangeContent(() => {
      preview.renderMarkup(getState())
      persist()
    })
    models.javascript.onDidChangeContent(() => {
      persist()
    })

    // ▶ JS実行
    document.getElementById('btn-run')!.addEventListener('click', () => {
      preview.runWithJs(getState())
    })

    // ■ 強制終了: iframe を破棄・再生成して HTML/CSS のみ再描画。
    document.getElementById('btn-stop')!.addEventListener('click', () => {
      preview.forceStop(getState())
    })

    // 環境初期化: localStorage をクリアしてリロード。
    document.getElementById('btn-reset')!.addEventListener('click', () => {
      const ok = confirm(
        '保存されたコードをすべて削除して初期状態に戻します。よろしいですか？'
      )
      if (!ok) return
      clearCode()
      location.reload()
    })
  }

  init().catch((error) => {
    console.error('エディタの初期化に失敗しました:', error)
  })
</script>
